    "onboarding.quickadd.body" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌥Leertaste aus jeder App drücken, um das Schnelleingabe-Panel zu öffnen. Aufgabe eintippen und Return drücken. Fertig.\n\nDas Tastenkürzel kann jederzeit in den Einstellungen angepasst werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Press ⌥Space from any app to open the Quick Add panel. Type your task and hit Return. Done.\n\nYou can customize the shortcut any time in Settings."
          }
        }
      }
    },
    "onboarding.quickadd.subtitle" : {
