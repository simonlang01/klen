    "onboarding.groups.body" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gruppen für Arbeit, Privates oder beliebige Projekte erstellen. Dashboard mit einem Klick filtern.\n\nAufgaben ohne Gruppe landen in \"Nicht zugeordnet\" – immer sichtbar, nie verloren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Create groups for Work, Personal, or any project. Filter the dashboard with a single click.\n\nTasks without a group live in Unassigned — always visible, never lost."
          }
        }
      }
    },
    "onboarding.groups.subtitle" : {
      "localizations" : {
