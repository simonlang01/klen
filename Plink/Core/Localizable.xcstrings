        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Shortcut"
          }
        }
      }
    },
    "help.settings.s3.warning" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘Leertaste vermeiden — sie ist für Spotlight reserviert."
          }
