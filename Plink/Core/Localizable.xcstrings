        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avoid ⌘Space — it is reserved by Spotlight."
          }
        }
      }
    },
    "help.settings.s4.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Zurücksetzen-Button löscht alle Aufgaben und Gruppen endgültig und setzt Plink auf den Ausgangszustand zurück. Ein Bestätigungsdialog zeigt die genaue Anzahl der zu löschenden Einträge."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The Reset button permanently deletes all tasks and groups and returns Plink to a clean state. A confirmation dialog shows the exact number of items that will be deleted."
          }
        }
      }
    },
    "help.settings.s4.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
