    "help.smart.s1.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die smarte Eingabe ermöglicht es, Aufgaben in natürlicher Sprache zu beschreiben. Plink erkennt automatisch Titel, Datum und Priorität — ohne manuelle Eingabe."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Smart Input lets you describe a task in plain, natural language. Plink automatically extracts the title, due date and priority from your text — no need to set them manually."
          }
        }
      }
    },
    "help.smart.s1.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Was ist die smarte Eingabe?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What is Smart Input?"
          }
        }
      }
    },
    "help.smart.s2.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unter Einstellungen → Smarte Eingabe den Schalter aktivieren. Ein ✦-Smart-Button erscheint dann in der Schnelleingabe und im Neue-Aufgabe-Dialog."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Go to Settings → Smart Input and turn on the toggle. A ✦ Smart button will appear in the Quick Add panel and the New Task sheet."
          }
        }
      }
    },
    "help.smart.s2.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Smarte Eingabe aktivieren"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enabling Smart Input"
          }
        }
      }
    },
    "help.smart.s3.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• \"Morgen John anrufen, dringend\" → Titel: John anrufen · Datum: Morgen · Priorität: Hoch\n• \"Lebensmittel in zwei Wochen kaufen\" → Titel: Lebensmittel kaufen · Datum: in 14 Tagen\n• \"Mittwoch, Präsentation vorbereiten\" → Titel: Präsentation vorbereiten · Datum: nächsten Mittwoch\n• \"Team-Meeting nächsten Montag, wichtig\" → Titel: Team-Meeting · Datum: nächsten Montag · Priorität: Mittel"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• \"Call John tomorrow, urgent\" → Title: Call John · Due: Tomorrow · Priority: High\n• \"Buy groceries in two weeks\" → Title: Buy groceries · Due: in 14 days\n• \"Wednesday, prepare the presentation\" → Title: Prepare the presentation · Due: next Wednesday\n• \"Team sync next Monday, important\" → Title: Team sync · Due: next Monday · Priority: Medium"
          }
        }
      }
    },
    "help.smart.s3.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beispiele"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Example inputs"
          }
        }
      }
    },
    "help.smart.s4.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Heute · Morgen · Nächsten/diesen [Wochentag] · [Wochentag] in X Wochen · In X Tagen/Wochen/Monaten · Absolute Daten (z.B. 15. Januar)"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Today · Tomorrow · Next/this [weekday] · [Weekday] in X weeks · In X days/weeks/months · Absolute dates (e.g. January 15)"
          }
        }
      }
    },
    "help.smart.s4.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unterstützte Datumsangaben"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Supported date expressions"
          }
        }
      }
    },
    "help.smart.s5.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hoch: dringend, sofort, kritisch, super dringend, sofort\nMittel: wichtig, bald\nNiedrig: irgendwann, kein Stress"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "High: urgent, asap, critical, super urgent, immediately\nMedium: important, soon\nLow: whenever, someday, no rush"
          }
        }
      }
    },
    "help.smart.s5.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unterstützte Prioritätswörter"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Supported priority words"
          }
        }
      }
    },
    "help.smart.s5.tip" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deutsche Schlüsselwörter werden unterstützt: dringend, sofort, wichtig, bald, irgendwann."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "German keywords are also supported: dringend, sofort, wichtig, bald, irgendwann."
          }
        }
      }
    },
    "help.smart.s6.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Auf macOS 26+ mit aktivierter Apple Intelligence verwendet die smarte Eingabe das lokale Sprachmodell für beste Ergebnisse. Auf älteren Systemen wird Apples Natural-Language-Framework verwendet — etwas weniger präzise, aber vollständig privat."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "On macOS 26+ with Apple Intelligence enabled, Smart Input uses the on-device language model for best results. On earlier systems it uses Apple's Natural Language framework — slightly less precise but fully private."
          }
        }
      }
    },
    "help.smart.s6.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Engine"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Engine"
          }
        }
      }
    },
    "help.smart.s6.tip" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle Verarbeitung erfolgt auf dem Gerät. Es werden keine Daten an Server gesendet."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All processing is on-device. Nothing is sent to any server."
          }
        }
      }
    },
    "help.smart.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Smarte Eingabe"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Smart Input"
          }
        }
      }
    },
    "help.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hilfe"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Help"
          }
        }
      }
    },
    "help.trash.s1.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Papierkorb enthält zwei Arten von Einträgen:\n• Gelöschte Aufgaben — manuell gelöscht oder beim Löschen einer Gruppe\n• Erledigte Aufgaben — nach dem 30-Minuten-Sichtbarkeitsfenster hierher verschoben"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trash contains two kinds of items:\n• Deleted tasks — manually deleted from the dashboard or when a group was deleted\n• Completed tasks — moved here after the 30-minute visibility window"
          }
        }
      }
    },
    "help.trash.s1.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Was im Papierkorb erscheint"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What appears in Trash"
          }
        }
      }
    },
    "help.trash.s2.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Über eine Aufgabe im Papierkorb hovern und auf \"Wiederherstellen\" klicken, oder Rechtsklick und \"Wiederherstellen\" wählen. Die Aufgabe kehrt als offene Aufgabe in die Übersicht zurück."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hover over a task in Trash and click Restore, or right-click and choose Restore. The task returns to the dashboard as an open task."
          }
        }
      }
    },
    "help.trash.s2.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aufgabe wiederherstellen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restoring a task"
          }
        }
      }
    },
    "help.trash.s3.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Über eine Aufgabe hovern und auf \"Löschen\" klicken, oder den \"Leeren\"-Button neben jedem Abschnitt-Header verwenden, um alle Einträge auf einmal zu entfernen.\n\nDer \"Papierkorb leeren\"-Button in der Symbolleiste löscht alles auf einmal endgültig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hover over a task and click Delete, or use the Clear button next to each section header to remove all items in that section at once.\n\nThe Empty Trash button in the toolbar permanently deletes everything in one action."
          }
        }
      }
    },
    "help.trash.s3.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Endgültig löschen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permanent deletion"
          }
        }
      }
    },
    "help.trash.s3.warning" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Endgültiges Löschen kann nicht rückgängig gemacht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permanent deletion cannot be undone."
          }
        }
      }
    },
    "help.trash.s4.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einträge im Papierkorb werden nach 6 Monaten automatisch und endgültig gelöscht. Es ist keine manuelle Aktion erforderlich."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Items in Trash are automatically and permanently deleted after 6 months. There is no manual action required."
          }
        }
      }
    },
    "help.trash.s4.heading" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automatische Bereinigung"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automatic cleanup"
          }
        }
      }
    },
    "help.trash.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Papierkorb"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trash"
          }
        }
      }
    },
    "onboarding.accent.subtitle" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine Akzentfarbe wählen, um Plink zu personalisieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pick an accent color to personalise Plink."
          }
        }
      }
    },
    "onboarding.accent.title" : {
      "localizations" : {
