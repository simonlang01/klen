      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Return — Speichern und schließen\n⌘Return — Speichern und schließen (Alternative)\nShift+Return — Neue Zeile im Beschreibungsfeld\nEsc — Änderungen verwerfen und schließen"
