            "value" : "Mach es zu deinem"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Make it yours"
          }
        }
      }
    },
    "onboarding.button.continue" : {
      "extractionState" : "stale",
      "localizations" : {
